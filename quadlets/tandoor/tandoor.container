[Unit]
Description=Tandoor
Wants=tandoor-db.service
Wants=tandoor-nginx.service
After=tandoor.service

[Service]
Restart=on-failure
TimeoutStartSec=900

[Install]
WantedBy=default.target

[Container]
Image=docker.io/vabene1111/recipes
ContainerName=tandoor-db
HostName=tandoor-db

Volume=tandoor-db:/var/lib/postgresql/data

EnvironmentFile=tandoor.env
